#!/bin/bash

# =============================================================================
# ZFS Snapshot Destroyer - Interactive Edition
# =============================================================================
# Lists all datasets that have snapshots and allows interactive selection
# Requires sudo privileges to run
# =============================================================================

# Color definitions for better readability
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# -----------------------------------------------------------------------------
# Check if running with sudo privileges
# -----------------------------------------------------------------------------
check_sudo() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Error: This script must be run with sudo privileges${NC}"
        echo "Usage: sudo $0"
        exit 1
    fi
}

# -----------------------------------------------------------------------------
# Get all datasets that have at least one snapshot
# Returns unique dataset names (without the snapshot part)
# -----------------------------------------------------------------------------
get_datasets_with_snapshots() {
    zfs list -H -o name -t snapshot 2>/dev/null | cut -d'@' -f1 | sort -u
}

# -----------------------------------------------------------------------------
# Count snapshots for a given dataset
# -----------------------------------------------------------------------------
count_snapshots() {
    local dataset="$1"
    zfs list -H -o name -t snapshot -r "$dataset" 2>/dev/null | grep "^${dataset}@" | wc -l
}

# -----------------------------------------------------------------------------
# Display the list of datasets with snapshots
# -----------------------------------------------------------------------------
display_dataset_list() {
    local -n datasets_ref=$1
    local i=1
    
    echo ""
    echo -e "${CYAN}============================================${NC}"
    echo -e "${CYAN}  Datasets with Snapshots${NC}"
    echo -e "${CYAN}============================================${NC}"
    echo ""
    
    for dataset in "${datasets_ref[@]}"; do
        local snap_count=$(count_snapshots "$dataset")
        printf "  ${GREEN}[%2d]${NC}  %-40s ${YELLOW}(%d snapshots)${NC}\n" "$i" "$dataset" "$snap_count"
        ((i++))
    done
    
    echo ""
    echo -e "${CYAN}--------------------------------------------${NC}"
    echo -e "  ${GREEN}[q]${NC}   Quit"
    echo -e "${CYAN}--------------------------------------------${NC}"
    echo ""
}

# -----------------------------------------------------------------------------
# Show warning and get confirmation before destroying snapshots
# -----------------------------------------------------------------------------
confirm_destruction() {
    local dataset="$1"
    local snap_count=$(count_snapshots "$dataset")
    
    echo ""
    echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║${YELLOW}                        ⚠️  WARNING ⚠️ ${NC}  ${RED}                         ║${NC}"
    echo -e "${RED}╠════════════════════════════════════════════════════════════════╝${NC}"
    echo -e "${RED}║${NC} ${CYAN}You are about to destroy ALL snapshots for:${NC}"
    echo -e "${RED}║${NC}"
    echo -e "${RED}║${NC}${CYAN}  Dataset: ${YELLOW}${dataset}${NC}"
    printf "${RED}║${NC}${CYAN}  %-62s${RED}${NC}\n" ""
    echo -e "${RED}║${NC}${CYAN}  Number of snapshots to be destroyed: ${YELLOW}${snap_count}${NC}"
    printf "${RED}║${NC}${CYAN}  %-62s${RED}${NC}\n" ""
    echo -e "${RED}║${NC}"
    echo -e "${RED}║${NC}                ${RED}THIS ACTION CANNOT BE UNDONE!${NC}"
    echo -e "${RED}╚═════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    echo -e "${YELLOW}Is this the dataset you want to delete all snapshots from?${NC}"
    echo -n "Type 'yes' to confirm, or anything else to cancel: "
    read -r confirmation
    
    if [[ "$confirmation" == "yes" ]]; then
        return 0
    else
        return 1
    fi
}

# -----------------------------------------------------------------------------
# Destroy all snapshots for a given dataset
# -----------------------------------------------------------------------------
destroy_snapshots() {
    local dataset="$1"
    
    echo ""
    echo -e "${CYAN}Destroying snapshots for: ${YELLOW}${dataset}${NC}"
    echo -e "${CYAN}--------------------------------------------${NC}"
    
    # Get all snapshots for this specific dataset (not recursive into child datasets)
    zfs list -H -o name -t snapshot 2>/dev/null | grep "^${dataset}@" | while read -r snap; do
        echo -e "  Destroying: ${YELLOW}${snap}${NC}"
        if zfs destroy "$snap" 2>/dev/null; then
            echo -e "    ${GREEN}✓ Success${NC}"
        else
            echo -e "    ${RED}✗ Failed${NC}"
        fi
    done
    
    echo ""
    echo -e "${GREEN}Done! All snapshots for ${dataset} have been processed.${NC}"
}

# -----------------------------------------------------------------------------
# Main function
# -----------------------------------------------------------------------------
main() {
    # Check for sudo privileges
    check_sudo
    
    # Clear screen for clean interface
    clear
    
    echo -e "${GREEN}"
    echo "  ╔═══════════════════════════════════════════════════════════╗"
    echo "  ║     Nordix: ZFS Snapshot Destroyer - Interactive Mode     ║"
    echo "  ╚═══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    
    # Get datasets with snapshots into an array
    mapfile -t datasets < <(get_datasets_with_snapshots)
    
    # Check if any datasets have snapshots
    if [[ ${#datasets[@]} -eq 0 ]]; then
        echo -e "${YELLOW}No datasets with snapshots found.${NC}"
        exit 0
    fi
    
    # Main loop
    while true; do
        # Refresh the dataset list each iteration
        mapfile -t datasets < <(get_datasets_with_snapshots)
        
        # Check if any datasets remain
        if [[ ${#datasets[@]} -eq 0 ]]; then
            echo -e "${YELLOW}No more datasets with snapshots.${NC}"
            exit 0
        fi
        
        # Display the list
        display_dataset_list datasets
        
        # Get user selection
        echo -n "Enter selection number (or 'q' to quit): "
        read -r selection
        
        # Handle quit
        if [[ "$selection" == "q" || "$selection" == "Q" ]]; then
            echo -e "${GREEN}Exiting. Goodbye!${NC}"
            exit 0
        fi
        
        # Validate input is a number
        if ! [[ "$selection" =~ ^[0-9]+$ ]]; then
            echo -e "${RED}Invalid input. Please enter a number.${NC}"
            sleep 1
            continue
        fi
        
        # Validate selection range
        if [[ "$selection" -lt 1 || "$selection" -gt ${#datasets[@]} ]]; then
            echo -e "${RED}Invalid selection. Please choose a number between 1 and ${#datasets[@]}.${NC}"
            sleep 1
            continue
        fi
        
        # Get selected dataset (array is 0-indexed, selection is 1-indexed)
        selected_dataset="${datasets[$((selection - 1))]}"
        
        # Confirm destruction
        if confirm_destruction "$selected_dataset"; then
            destroy_snapshots "$selected_dataset"
            echo ""
            echo -e "${CYAN}Press Enter to continue...${NC}"
            read -r
        else
            echo -e "${YELLOW}Operation cancelled.${NC}"
            sleep 1
        fi
    done
}

# Run main function
main
